<Window x:Class="DeviceDebugStudio.App.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="在线更新"
        Width="440"
        Height="238"
        MinWidth="440"
        MinHeight="238"
        MaxWidth="440"
        MaxHeight="238"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackgroundBrush}"
        FontSize="12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="OnWindowClosing">
    <Window.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="9" />
            <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="18" />
            <RowDefinition Height="22" />
            <RowDefinition Height="24" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <ui:SymbolIcon Width="20"
                           Height="20"
                           Margin="0,0,9,0"
                           FontSize="19"
                           Symbol="ArrowSync20"
                           Foreground="{DynamicResource ButtonForegroundBrush}" />
            <TextBlock VerticalAlignment="Center"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ButtonForegroundBrush}"
                       Text="在线更新" />
        </StackPanel>

        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Text="当前版本" />
            <TextBlock x:Name="CurrentVersionText"
                       Grid.Column="1"
                       Margin="8,0,18,0"
                       Foreground="{DynamicResource ButtonForegroundBrush}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="2"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Text="目标版本" />
            <TextBlock x:Name="TargetVersionText"
                       Grid.Column="3"
                       Margin="8,0,0,0"
                       Foreground="{DynamicResource ButtonForegroundBrush}"
                       TextTrimming="CharacterEllipsis" />
        </Grid>

        <ProgressBar x:Name="DownloadProgressBar"
                     Grid.Row="2"
                     Minimum="0"
                     Maximum="1"
                     Value="0"
                     IsIndeterminate="True"
                     VerticalAlignment="Center" />

        <Grid Grid.Row="3" Margin="0,6,0,0">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Top"
                       Foreground="{DynamicResource ButtonForegroundBrush}"
                       Text="正在准备下载…"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="PercentText"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Text="—" />
        </Grid>

        <TextBlock x:Name="PackageText"
                   Grid.Row="4"
                   Margin="0,3,0,0"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="等待连接更新服务器…"
                   TextTrimming="CharacterEllipsis" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button x:Name="CancelButton"
                    Width="72"
                    Height="28"
                    Content="取消"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
