<Window x:Class="DeviceDebugStudio.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:converters="clr-namespace:DeviceDebugStudio.App.Converters"
                 xmlns:core="clr-namespace:DeviceDebugStudio.Core.Transports;assembly=DeviceDebugStudio.Core"
                 xmlns:infra="clr-namespace:DeviceDebugStudio.Infrastructure.Transports;assembly=DeviceDebugStudio.Infrastructure"
                 xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 mc:Ignorable="d"
                 Title="嵌入式调试台"
                 Icon="Assets/DeviceDebugStudio.ico"
                 Width="1280"
                 Height="720"
                 MinWidth="900"
                 MinHeight="620"
                 FontSize="12"
                 Background="{DynamicResource WorkspaceBackgroundBrush}"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True"
                 WindowStartupLocation="CenterScreen"
                 SizeChanged="OnWindowSizeChanged"
                  Closing="OnWindowClosing">
    <Window.Resources>
        <converters:TerminalDisplayTextConverter x:Key="TerminalDisplayTextConverter" />
        <Style x:Key="SeparatedHorizontalScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Height="8"
                                       VerticalAlignment="Center"
                                       Style="{x:Null}"
                                       Background="Transparent"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Orientation="Horizontal"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid Background="Transparent">
                                            <Border Height="3"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource DividerBrush}"
                                                    CornerRadius="1.5" />
                                            <Track x:Name="PART_Track"
                                                   IsDirectionReversed="False"
                                                   Orientation="Horizontal">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                                                  Focusable="False"
                                                                  Opacity="0" />
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb MinWidth="24">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                                <Border x:Name="ThumbBorder"
                                                                        Height="6"
                                                                        VerticalAlignment="Center"
                                                                        Background="{DynamicResource MutedTextBrush}"
                                                                        CornerRadius="3"
                                                                        Opacity="0.75" />
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="1" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                                                  Focusable="False"
                                                                  Opacity="0" />
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Width="22"
                                   Height="22"
                                   VerticalAlignment="Center"
                                   Symbol="DeveloperBoard24"
                                   FontSize="20"
                                   Foreground="{DynamicResource ButtonForegroundBrush}" />
                    <TextBlock Margin="7,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="Normal"
                               Foreground="{DynamicResource ButtonForegroundBrush}"
                               Text="嵌入式调试台" />
                    <Border Margin="10,0,0,0"
                            Padding="7,3"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SidebarBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding ConnectionSummary}" />
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="显示或隐藏设备面板" Click="OnToggleDevicePanelClick">
                        <ui:SymbolIcon Symbol="PanelLeft20" Width="17" Height="17" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="切换主题" Click="OnToggleThemeClick">
                        <ui:SymbolIcon Symbol="DarkTheme20" Width="17" Height="17" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="显示或隐藏命令面板" Click="OnToggleCommandPanelClick">
                        <ui:SymbolIcon Symbol="PanelRight20" Width="17" Height="17" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="打开捕获数据库" Click="OnOpenCaptureClick">
                        <ui:SymbolIcon Symbol="FolderOpen20" Width="17" Height="17" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}"
                            ToolTip="检查 GitHub 更新"
                            Click="OnCheckForUpdatesClick">
                        <ui:SymbolIcon Symbol="ArrowSync20" Width="17" Height="17" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="设置" Click="OnOpenSettingsClick">
                        <ui:SymbolIcon Symbol="Settings20" Width="17" Height="17" FontSize="17" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid x:Name="PanelLayoutGrid" Grid.Row="1" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="DevicePanelColumn" Width="0" />
                    <ColumnDefinition x:Name="DeviceSplitterColumn" Width="0" />
                    <ColumnDefinition x:Name="WorkspaceColumn" MinWidth="480" Width="*" />
                    <ColumnDefinition x:Name="CommandSplitterColumn" Width="5" />
                    <ColumnDefinition x:Name="CommandPanelColumn" MinWidth="480" MaxWidth="620" Width="500" />
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="2,0,2,8">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="设备工作区" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="新增设备" Command="{Binding AddProfileCommand}">
                                <ui:SymbolIcon Symbol="Add20" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="删除设备" Click="OnDeleteProfileClick">
                                <ui:SymbolIcon Symbol="Delete20" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ProfileItemBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ProfileItemBorder" Property="Background" Value="{DynamicResource ButtonSurfaceBrush}" />
                                                    <Setter TargetName="ProfileItemBorder" Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ProfileItemBorder" Property="Background" Value="{DynamicResource ButtonSurfaceBrush}" />
                                                    <Setter TargetName="ProfileItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ProfileItemBorder" Property="Opacity" Value="0.5" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,5" MinHeight="38">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4">
                                        <ui:SymbolIcon Foreground="{DynamicResource AccentBrush}">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="{x:Type ui:SymbolIcon}">
                                                    <Setter Property="Symbol" Value="UsbPlug20" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Transport.Kind}" Value="TcpClient">
                                                            <Setter Property="Symbol" Value="Server20" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Transport.Kind}" Value="TcpServer">
                                                            <Setter Property="Symbol" Value="Server20" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Transport.Kind}" Value="Udp">
                                                            <Setter Property="Symbol" Value="VirtualNetwork20" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Transport.Kind}" Value="BleGatt">
                                                            <Setter Property="Symbol" Value="Bluetooth20" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding Transport.Kind}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="当前设备名称" />
                        <TextBox Margin="0,0,0,7" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                        <Button x:Name="ProfileActionsButton" Margin="0,0,0,6" Padding="8,6" HorizontalContentAlignment="Left" Click="OnOpenProfileActionsClick">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="ProfileActionsMenu">
                                    <MenuItem Header="导入 SSCOM / NetAssist" Click="OnImportLegacyClick" />
                                    <Separator />
                                    <MenuItem Header="导入设备配置 JSON" Click="OnImportDeviceProfileClick" />
                                    <MenuItem Header="导出当前设备 JSON" Click="OnExportDeviceProfileClick" />
                                    <Separator />
                                    <MenuItem Header="打开捕获数据库" Click="OnOpenCaptureClick" />
                                    <MenuItem Header="选择配置保存目录" Click="OnConfigureProfileDirectoryClick" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="MoreHorizontal20" />
                                <TextBlock Margin="8,0,0,0" Text="配置操作" />
                            </StackPanel>
                        </Button>
                        <Button Padding="8,6" HorizontalContentAlignment="Left" Command="{Binding SaveSelectedProfileCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Save20" />
                                <TextBlock Margin="8,0,0,0" Text="保存设备配置" />
                            </StackPanel>
                        </Button>
                        <TextBlock Margin="2,6,2,0"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding ProfileDirectory}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ProfileDirectory}" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"
                          DragCompleted="OnDeviceSplitterDragCompleted" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="8,5"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <ListBox ItemsSource="{Binding WorkspaceModes}"
                             SelectedItem="{Binding SelectedWorkspaceMode}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="MinWidth" Value="104" />
                                <Setter Property="Height" Value="34" />
                                <Setter Property="Margin" Value="0,0,5,0" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Background" Value="{DynamicResource ButtonSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ModeBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ModeBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                                 <Trigger Property="IsSelected" Value="True">
                                                     <Setter TargetName="ModeBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                 </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ModeBorder" Property="Opacity" Value="0.5" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Width="16" Height="16" Margin="0,0,7,0" FontSize="16">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="SerialPort20" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mode}" Value="Network">
                                                        <Setter Property="Symbol" Value="VirtualNetwork20" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Mode}" Value="Bluetooth">
                                                        <Setter Property="Symbol" Value="Bluetooth20" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Mode}" Value="Modbus">
                                                        <Setter Property="Symbol" Value="TableSwitch20" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                    <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="Normal" Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1"
                        Height="46"
                        Padding="8,4"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" Orientation="Horizontal" VerticalAlignment="Top">
                            <ui:ToggleSwitch Height="24" Margin="0,0,8,0" FontSize="10" Content="自动重连" IsChecked="{Binding AutoReconnect}" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Height="24"
                                    MinHeight="24"
                                    Padding="6,2"
                                    FontSize="10"
                                    Command="{Binding ToggleConnectionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Width="13" Height="13" Margin="0,0,3,0" Symbol="PlugConnected20" />
                                    <TextBlock Text="{Binding ConnectionButtonText}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <ScrollViewer Grid.Column="0"
                                      Height="36"
                                      Style="{StaticResource SeparatedHorizontalScrollViewerStyle}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Top"
                                      VerticalContentAlignment="Top"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox Width="100"
                                      Height="24"
                                      Margin="0,0,4,0"
                                      ItemsSource="{Binding AvailableTransportOptions}"
                                      SelectedItem="{Binding SelectedTransportOption}"
                                      DisplayMemberPath="Name">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox" BasedOn="{StaticResource ConnectionComboBoxStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsModbusWorkspace}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Serial">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsModbusWorkspace}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox Width="76"
                                          Height="24"
                                          Style="{StaticResource ConnectionComboBoxStyle}"
                                          Margin="0,0,2,0"
                                          ItemsSource="{Binding SerialPorts}"
                                          SelectedValue="{Binding PortName}"
                                          SelectedValuePath="PortName"
                                          DisplayMemberPath="CompactDisplayName"
                                          ToolTip="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource Self}}" />
                                <Button Style="{StaticResource CompactIconButtonStyle}" ToolTip="刷新串口" Command="{Binding RefreshPortsCommand}">
                                    <ui:SymbolIcon Symbol="ArrowSync20" FontSize="14" />
                                </Button>
                                <ComboBox Width="88" Height="24" Style="{StaticResource ConnectionComboBoxStyle}" Margin="2,0,4,0" IsEditable="True" ItemsSource="{Binding BaudRates}" Text="{Binding BaudRate}" />
                                <CheckBox Width="76" MinWidth="76" Height="24" Margin="0,0,3,0" VerticalAlignment="Center" FontSize="10" Content="DTR" IsChecked="{Binding DtrEnable}" />
                                <CheckBox Width="76" MinWidth="76" Height="24" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" Content="RTS" IsChecked="{Binding RtsEnable}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="TcpClient">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Udp">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="140" Height="24" Margin="0,0,5,0" Style="{StaticResource ConnectionTextBoxStyle}" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" ToolTip="远端地址" />
                                <TextBox Width="64" Height="24" Margin="0,0,6,0" Style="{StaticResource ConnectionTextBoxStyle}" Text="{Binding RemotePort}" ToolTip="远端端口" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="TcpServer">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Udp">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="112" Height="24" Margin="0,0,5,0" Style="{StaticResource ConnectionTextBoxStyle}" Text="{Binding LocalAddress}" ToolTip="本地地址" />
                                <TextBox Width="64" Height="24" Margin="0,0,6,0" Style="{StaticResource ConnectionTextBoxStyle}" Text="{Binding LocalPort}" ToolTip="本地端口" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="BleGatt">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox Width="210" Height="24" Style="{StaticResource ConnectionComboBoxStyle}" Margin="0,0,4,0" ItemsSource="{Binding BleDevices}" SelectedItem="{Binding SelectedBleDevice}" DisplayMemberPath="DisplayName" />
                                <Button Style="{StaticResource CompactIconButtonStyle}" ToolTip="扫描 BLE" Command="{Binding ScanBleCommand}">
                                    <ui:SymbolIcon Symbol="BluetoothSearching20" Width="14" Height="14" />
                                </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <TabControl Grid.Row="2" Margin="8,6,8,8" SelectedIndex="{Binding SelectedWorkspaceTabIndex}">
                    <TabItem Header="{Binding TerminalTabHeader}">
                        <Grid PreviewMouseWheel="OnTerminalPreviewMouseWheel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="110" MinHeight="110" MaxHeight="330" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:ToggleSwitch Height="24" Margin="0,0,8,0" FontSize="11" Content="HEX" FocusVisualStyle="{x:Null}" IsChecked="{Binding ReceiveAsHex}" ToolTip="HEX 显示：仅切换通信记录显示，不影响发送格式" />
                                    <ui:ToggleSwitch Height="24" Margin="0,0,8,0" FontSize="11" Content="暂停显示" FocusVisualStyle="{x:Null}" IsChecked="{Binding IsPaused}" ToolTip="暂停把新通信记录加入终端显示；连接和接收计数继续运行" />
                                    <ui:ToggleSwitch Height="24" Margin="0,0,6,0" FontSize="11" Content="自动滚动" FocusVisualStyle="{x:Null}" IsChecked="{Binding AutoScroll}" ToolTip="显示新记录时自动滚动到底部，不影响数据接收" />
                                    <Button Style="{StaticResource CompactIconButtonStyle}"
                                            ToolTip="清空显示"
                                            Command="{Binding ClearTerminalCommand}">
                                        <ui:SymbolIcon Symbol="Delete20" Width="14" Height="14" />
                                    </Button>
                                    <Button x:Name="TerminalMoreButton"
                                            Style="{StaticResource CompactIconButtonStyle}"
                                            ToolTip="更多终端操作"
                                            Click="OnOpenTerminalMoreMenuClick">
                                        <Button.ContextMenu>
                                            <ContextMenu x:Name="TerminalMoreMenu"
                                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="保存连续文本 TXT" Click="OnSaveTerminalPlainTextClick">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Save20" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="导出表格 CSV" Click="OnExportTerminalTableCsvClick">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="DocumentTable20" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <ui:SymbolIcon Symbol="MoreHorizontal20" Width="14" Height="14" />
                                    </Button>
                                </StackPanel>
                                <Border Grid.Column="0"
                                        Width="260"
                                        MinHeight="32"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource PanelBackgroundBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0"
                                                       Width="16"
                                                       Height="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Symbol="Search20"
                                                       IsHitTestVisible="False" />
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource CompactTextBoxStyle}"
                                                 MinHeight="28"
                                                 Padding="4,3,7,3"
                                                 FontSize="13"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="搜索时间、字节、方向、端点或内容" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <TabControl x:Name="TerminalDisplayTabs"
                                        Grid.Row="1"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        SelectionChanged="OnTerminalDisplaySelectionChanged">
                                <TabItem x:Name="TerminalPlainTextTab" Header="连续文本">
                                    <TextBox x:Name="TerminalPlainTextBox"
                                             Style="{StaticResource TerminalPlainTextBoxStyle}"
                                             FontSize="{Binding TerminalFontSize}">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="复制" Command="{x:Static ApplicationCommands.Copy}" />
                                                <MenuItem Header="全选" Click="OnSelectAllTerminalTextClick" />
                                                <Separator />
                                                <MenuItem Header="保存连续文本 TXT" Click="OnSaveTerminalPlainTextClick" />
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </TabItem>
                                <TabItem x:Name="TerminalTableTab" Header="表格">
                                    <ListView x:Name="TerminalList"
                                      ItemsSource="{Binding TerminalRecords}"
                                      SelectionMode="Extended"
                                      SizeChanged="OnTerminalListSizeChanged"
                                      ScrollViewer.ScrollChanged="OnTerminalListScrollChanged"
                                      PreviewKeyDown="OnTerminalPreviewKeyDown"
                                      Background="{DynamicResource TerminalBackgroundBrush}"
                                      Foreground="{DynamicResource TerminalTextBrush}"
                                      BorderThickness="0"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="{Binding TerminalFontSize}"
                                       ScrollViewer.CanContentScroll="True"
                                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                       VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#315F58" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#284C48" />
                                </ListView.Resources>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制所选整行" Click="OnCopySelectedTerminalRowsClick" />
                                        <MenuItem Header="全选所有行" Click="OnSelectAllTerminalRowsClick" />
                                        <Separator />
                                        <MenuItem Header="导出表格 CSV" Click="OnExportTerminalTableCsvClick" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="26" />
                                        <Setter Property="Padding" Value="3,0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn x:Name="TerminalTimeColumn" Width="122" Header="时间">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             ToolTip="{Binding TimeText}"
                                                             Text="{Binding TimeText, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalDirectionColumn" Width="84" Header="方向">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             ToolTip="{Binding DirectionText}"
                                                             Text="{Binding DirectionText, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalEndpointColumn" Width="150" Header="端点">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             ToolTip="{Binding Endpoint}"
                                                             Text="{Binding Endpoint, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalSizeColumn" Width="66" Header="字节">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             ToolTip="{Binding Size}"
                                                             Text="{Binding Size, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalContentColumn" Width="760">
                                            <GridViewColumn.Header>
                                                <GridViewColumnHeader Content="内容" IsHitTestVisible="False" />
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}">
                                                        <TextBox.Text>
                                                            <MultiBinding Mode="OneWay" Converter="{StaticResource TerminalDisplayTextConverter}">
                                                                <Binding />
                                                                <Binding Path="DataContext.ReceiveAsHex" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                                    </ListView>
                                </TabItem>
                            </TabControl>

                            <GridSplitter Grid.Row="2"
                                          Height="8"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          Cursor="SizeNS"
                                          ResizeDirection="Rows"
                                          ResizeBehavior="PreviousAndNext"
                                          ShowsPreview="True"
                                          ToolTip="上下拖动调整发送栏高度">
                                <GridSplitter.Template>
                                    <ControlTemplate TargetType="GridSplitter">
                                        <Grid Background="Transparent">
                                            <Border Width="40"
                                                    Height="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource MutedTextBrush}"
                                                    CornerRadius="1" />
                                        </Grid>
                                    </ControlTemplate>
                                </GridSplitter.Template>
                            </GridSplitter>

                            <Border Grid.Row="3" Padding="6" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Height="24" Margin="0,0,4,4" Style="{StaticResource ConnectionComboBoxStyle}" ItemsSource="{Binding EncodingNames}" SelectedItem="{Binding SelectedEncodingName}" />
                                    <ComboBox Grid.Column="1" Height="24" Margin="0,0,4,4" Style="{StaticResource ConnectionComboBoxStyle}" ItemsSource="{Binding LineEndings}" SelectedItem="{Binding SelectedLineEnding}" />
                                    <ComboBox Grid.Column="2" Height="24" Margin="0,0,4,4" Style="{StaticResource ConnectionComboBoxStyle}" ItemsSource="{Binding ChecksumKinds}" SelectedItem="{Binding SelectedSendChecksum}" />
                                    <StackPanel Grid.Column="3" Margin="0,0,4,4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <ui:ToggleSwitch Height="24" Margin="0,0,8,0" FontSize="10" Content="HEX 发送" IsChecked="{Binding SendAsHex}" ToolTip="开启后按十六进制字节解析发送框内容" />
                                        <ui:ToggleSwitch Height="24"
                                                         Margin="0,0,4,0"
                                                         FontSize="10"
                                                         Content="循环发送"
                                                         FocusVisualStyle="{x:Null}"
                                                         IsChecked="{Binding SendRepeatEnabled, Mode=TwoWay}"
                                                         ToolTip="启用循环发送；已连接且发送框非空时开始按间隔发送" />
                                        <TextBox Width="50"
                                                 Height="24"
                                                 Margin="0,0,2,0"
                                                 Style="{StaticResource ConnectionTextBoxStyle}"
                                                 FontSize="10"
                                                 HorizontalContentAlignment="Center"
                                                 Text="{Binding SendRepeatIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="循环发送间隔，单位 ms" />
                                        <TextBlock Margin="0,0,7,0" VerticalAlignment="Center" FontSize="10" Text="ms" />
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Serial">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Margin="0,0,3,0" VerticalAlignment="Center" FontSize="10" Text="收包超时" />
                                            <TextBox Width="38"
                                                     Height="24"
                                                     Style="{StaticResource ConnectionTextBoxStyle}"
                                                     FontSize="10"
                                                     HorizontalContentAlignment="Center"
                                                     Text="{Binding ReceiveTimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="仅串口有效；不同底层读取在此间隔内合并为一条记录" />
                                            <TextBlock Margin="2,0,0,0" VerticalAlignment="Center" FontSize="10" Text="ms" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="4"
                                            MinWidth="86"
                                            Height="26"
                                            Margin="6,0,0,4"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            ToolTip="选择并发送文件"
                                            Click="OnSendFileClick">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="DocumentArrowUp20" Width="16" Height="16" Margin="0,0,5,0" />
                                            <TextBlock Text="发送文件" />
                                        </StackPanel>
                                    </Button>
                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" MinHeight="52" Padding="7,5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="1" Grid.Column="4" Height="52" Margin="6,0,0,0" VerticalAlignment="Bottom" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SendCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Width="14" Height="14" Margin="0,0,3,0" Symbol="Send20" />
                                            <TextBlock Text="发送" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="帧解析" Visibility="{Binding IsFrameWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,7">
                                <ComboBox Width="115" Margin="0,0,6,0" ItemsSource="{Binding FramingModes}" SelectedItem="{Binding SelectedFramingMode}" />
                                <TextBox Width="110" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding DelimiterHex}" ToolTip="分隔符 HEX" />
                                <TextBox Width="68" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding FixedFrameLength}" ToolTip="固定帧长" />
                                <TextBox Width="60" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LengthFieldOffset}" ToolTip="长度字段偏移" />
                                <TextBox Width="60" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LengthFieldSize}" ToolTip="长度字段宽度" />
                                <TextBox Width="65" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding IdleGapMs}" ToolTip="空闲间隔 ms" />
                                <Button Padding="12,5" Command="{Binding ApplyFramingOptionsCommand}">应用分帧</Button>
                            </WrapPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ListView ItemsSource="{Binding FrameRecords}" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="90" Header="时间" DisplayMemberBinding="{Binding TimeText}" />
                                            <GridViewColumn Width="55" Header="长度" DisplayMemberBinding="{Binding Length}" />
                                            <GridViewColumn Width="360" Header="HEX" DisplayMemberBinding="{Binding Hex}" />
                                            <GridViewColumn Width="360" Header="字段" DisplayMemberBinding="{Binding Summary}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <Grid Grid.Column="2" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="设备帧模板 JSON" />
                                    <TextBox Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" FontFamily="Cascadia Mono, Consolas" FontSize="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Text="{Binding FrameTemplateJson, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="2" Margin="0,7,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button Margin="0,0,5,0" Padding="9,5" Click="OnImportFrameTemplateClick">导入</Button>
                                        <Button Margin="0,0,5,0" Padding="9,5" Click="OnExportFrameTemplateClick">导出</Button>
                                        <Button Padding="10,5" Command="{Binding ApplyFrameTemplateCommand}">校验并应用模板</Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="曲线" Visibility="{Binding IsChartWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="清空曲线" Click="OnClearChartClick">
                                        <ui:SymbolIcon Symbol="Delete20" />
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="导出 PNG" Click="OnExportChartClick">
                                        <ui:SymbolIcon Symbol="Save20" />
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="导出 CSV" Click="OnExportChartCsvClick">
                                        <ui:SymbolIcon Symbol="DocumentCsv20" />
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:ToggleSwitch Margin="0,0,8,0" Content="从文本提取数值" IsChecked="{Binding ChartAutoExtract}" />
                                    <TextBox Width="260" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ChartValuePattern, UpdateSourceTrigger=PropertyChanged}" ToolTip="数值正则表达式" />
                                </StackPanel>
                            </DockPanel>
                            <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="4">
                                <scott:WpfPlot x:Name="RealtimePlot" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Modbus" Visibility="{Binding IsModbusWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="站号" />
                                <TextBox Width="55" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusUnitId}" />
                                <ComboBox Width="150" Margin="0,0,8,0" ItemsSource="{Binding ModbusFunctions}" SelectedItem="{Binding SelectedModbusFunction}" />
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="地址" />
                                <TextBox Width="70" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusAddress}" />
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="数量/值" />
                                <TextBox Width="75" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusQuantityOrValue}" />
                                <TextBox Width="210" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusValues}" ToolTip="多值使用逗号或空格分隔" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SendModbusCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Send20" />
                                        <TextBlock Text="发送请求" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="270" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding ModbusRegisters}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="170" Header="寄存器地址" Binding="{Binding AddressText}" IsReadOnly="True" />
                                        <DataGridTextColumn Width="120" Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Width="120" Header="HEX" Binding="{Binding Value, StringFormat=0x{0:X4}}" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <StackPanel Grid.Column="2" Margin="10,4">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="从站模拟" />
                                    <ui:ToggleSwitch Content="启用 RTU/TCP 响应" IsChecked="{Binding ModbusSlaveEnabled}" />
                                    <TextBlock Margin="0,14,0,4" Style="{StaticResource SectionLabelStyle}" Text="事务编号" />
                                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusTransactionId}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="BLE GATT" Visibility="{Binding IsBluetoothWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8" LastChildFill="True">
                                <Button DockPanel.Dock="Right" Padding="10,5" Command="{Binding ScanBleCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="BluetoothSearching20" />
                                        <TextBlock Text="扫描设备" />
                                    </StackPanel>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Foreground="{DynamicResource MutedTextBrush}" Text="{Binding BleDevices.Count, StringFormat=发现 {0} 个 BLE GATT 设备}" />
                                    <TextBlock Margin="0,3,12,0"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               Text="{Binding BleDiscoveryNotice}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1.05*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <ListBox ItemsSource="{Binding BleDevices}" SelectedItem="{Binding SelectedBleDevice}" DisplayMemberPath="DisplayName" />
                                    <Button Grid.Row="1" Margin="0,7" Padding="10,5" HorizontalAlignment="Left" Command="{Binding BrowseGattCommand}">浏览所选设备 GATT</Button>
                                    <TreeView Grid.Row="2" ItemsSource="{Binding GattServices}" SelectedItemChanged="OnGattTreeSelectedItemChanged">
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type infra:BleGattServiceInfo}" ItemsSource="{Binding Characteristics}">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas" Text="{Binding DisplayName}" />
                                            </HierarchicalDataTemplate>
                                            <DataTemplate DataType="{x:Type infra:BleGattCharacteristicInfo}">
                                                <TextBlock Margin="12,0,0,0" FontFamily="Cascadia Mono, Consolas" Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </Grid>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <StackPanel Grid.Column="2" Margin="12,4">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="服务 UUID" />
                                    <TextBox Margin="0,0,0,10" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleServiceUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="写特征值 UUID" />
                                    <TextBox Margin="0,0,0,10" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleWriteUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="读特征值 UUID" />
                                    <DockPanel Margin="0,0,0,10">
                                        <Button DockPanel.Dock="Right" Margin="6,0,0,0" Padding="10,4" Command="{Binding ReadBleCommand}">读取</Button>
