                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center" FontSize="11" Text="发送预览" />
                                                            <TextBox Grid.Column="1"
                                                                     Height="28"
                                                                     Style="{StaticResource ConnectionTextBoxStyle}"
                                                                     IsReadOnly="True"
                                                                     FontFamily="Cascadia Mono, Consolas"
                                                                     Text="{Binding ResolvedPayload, Mode=OneWay}" />
                                                            <Button Grid.Column="2"
                                                                    Width="32"
                                                                    Height="28"
                                                                    Margin="6,0,0,0"
                                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                                    MinWidth="0"
                                                                    Padding="0"
                                                                    ToolTip="使用此方案发送"
                                                                    Command="{Binding DataContext.SendQuickCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <ui:SymbolIcon Symbol="Send20" Width="14" Height="14" />
                                                            </Button>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                            </Border>

                                            <Grid Grid.Row="1"
                                                  Grid.Column="0"
                                                  Grid.ColumnSpan="5"
                                                  Height="30"
                                                  Margin="0,3,0,0"
                                                  HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="76" />
                                                    <ColumnDefinition Width="86" />
                                                    <ColumnDefinition Width="82" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="1" ToolTip="按指令格式下勾选表示按 HEX 字节解析；切换不会改写指令内容">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Width="24"
                                                              MinWidth="24"
                                                              Height="24"
                                                              Padding="0"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              FocusVisualStyle="{x:Null}"
                                                              IsChecked="{Binding IsHex}" />
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource ButtonForegroundBrush}"
                                                               Text="HEX"
                                                               IsHitTestVisible="False" />
                                                </Grid>
                                                <ComboBox Grid.Column="2"
                                                          MinWidth="0"
                                                          Style="{StaticResource ConnectionComboBoxStyle}"
                                                          Margin="1,0"
                                                          Padding="2,0"
                                                          FontSize="10"
                                                          FocusVisualStyle="{x:Null}"
                                                          ItemsSource="{Binding DataContext.LineEndings, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding LineEnding}"
                                                          ToolTip="行尾追加方式" />
                                                <ComboBox Grid.Column="3"
                                                          MinWidth="0"
                                                          Style="{StaticResource ConnectionComboBoxStyle}"
                                                          Margin="1,0"
                                                          Padding="2,0"
                                                          FontSize="10"
                                                          FocusVisualStyle="{x:Null}"
                                                          ItemsSource="{Binding DataContext.ChecksumKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding Checksum}"
                                                          ToolTip="自动追加校验" />
                                                <Grid Grid.Column="4" Height="26" Margin="1,0">
                                                    <TextBox Style="{StaticResource ConnectionTextBoxStyle}"
                                                             MinWidth="0"
                                                             Height="26"
                                                             MinHeight="0"
                                                             Padding="2,1,18,1"
                                                             FontSize="10"
                                                             HorizontalContentAlignment="Center"
                                                             Text="{Binding RepeatIntervalMs}"
                                                             ToolTip="循环发送间隔" />
                                                    <TextBlock Margin="0,0,3,0"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               IsHitTestVisible="False"
                                                               Text="ms" />
                                                </Grid>
                                                <Button Grid.Column="5"
                                                        Style="{StaticResource CompactIconButtonStyle}"
                                                        Width="26"
                                                        MinWidth="0"
                                                        Height="26"
                                                        MinHeight="0"
                                                        Margin="1,0"
                                                        ToolTip="开始或停止循环发送"
                                                        ToolTipService.ShowOnDisabled="True"
                                                        ToolTipService.InitialShowDelay="200"
                                                        ToolTipService.ShowDuration="5000"
                                                        Command="{Binding DataContext.ToggleQuickRepeatCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Width="12" Height="12" FontSize="12">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Symbol" Value="ArrowRepeatAll20" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRepeating}" Value="True">
                                                                        <Setter Property="Symbol" Value="Pause20" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                </Button>
                                                <Button x:Name="QuickCommandDragHandle"
                                                        Grid.Column="6"
                                                        Style="{StaticResource CompactIconButtonStyle}"
                                                        Width="26"
                                                        MinWidth="0"
                                                        Height="26"
                                                        MinHeight="0"
                                                        Margin="1,0"
                                                        Cursor="SizeAll"
                                                        Focusable="False"
                                                        ToolTip="按住拖动调整顺序">
                                                    <ui:SymbolIcon Symbol="ArrowMove20" Width="12" Height="12" FontSize="12" />
                                                </Button>
                                                <Button Grid.Column="7"
                                                        Style="{StaticResource CompactIconButtonStyle}"
                                                        Width="26"
                                                        MinWidth="0"
                                                        Height="26"
                                                        MinHeight="0"
                                                        Margin="1,0"
                                                        ToolTip="删除"
                                                        Command="{Binding DataContext.DeleteQuickCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Delete20" Width="12" Height="12" FontSize="12" />
                                                </Button>
                                                <Button Grid.Column="8"
                                                        Width="26"
                                                        MinWidth="0"
                                                        Height="26"
                                                        MinHeight="0"
                                                        Margin="1,0"
                                                        Command="{Binding ToggleExpandedCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource CompactIconButtonStyle}">
                                                            <Setter Property="ToolTip" Value="展开快捷参数" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="ToolTip" Value="收起快捷参数" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ui:SymbolIcon Width="12" Height="12" FontSize="12">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Symbol" Value="ChevronDown20" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Symbol" Value="ChevronUp20" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="12,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding RateText}" />
                    <TextBlock Margin="12,0" Foreground="{DynamicResource ReceiveBrush}" Text="{Binding ReceivedBytes, StringFormat=RX {0:N0}}" />
                    <TextBlock Margin="12,0" Foreground="{DynamicResource SendBrush}" Text="{Binding SentBytes, StringFormat=TX {0:N0}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#8B9690" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#20A36A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
