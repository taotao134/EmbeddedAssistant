<Window x:Class="DeviceDebugStudio.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:converters="clr-namespace:DeviceDebugStudio.App.Converters"
                 xmlns:core="clr-namespace:DeviceDebugStudio.Core.Transports;assembly=DeviceDebugStudio.Core"
                 xmlns:infra="clr-namespace:DeviceDebugStudio.Infrastructure.Transports;assembly=DeviceDebugStudio.Infrastructure"
                 xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 mc:Ignorable="d"
                 Title="嵌入式调试台"
                 Width="1280"
                 Height="720"
                 MinWidth="900"
                 MinHeight="620"
                 WindowStartupLocation="CenterScreen"
                 SizeChanged="OnWindowSizeChanged"
                  Closing="OnWindowClosing">
    <Window.Resources>
        <converters:TerminalDisplayTextConverter x:Key="TerminalDisplayTextConverter" />
    </Window.Resources>
    <Grid Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="BotSparkle24" FontSize="22" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold" Text="嵌入式调试台" />
                    <Border Margin="12,0,0,0" Padding="8,3" Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="3">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding ConnectionSummary}" />
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="显示或隐藏设备面板" Click="OnToggleDevicePanelClick">
                        <ui:SymbolIcon Symbol="Bot20" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="切换主题" Click="OnToggleThemeClick">
                        <ui:SymbolIcon Symbol="DarkTheme20" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="显示或隐藏命令面板" Click="OnToggleCommandPanelClick">
                        <ui:SymbolIcon Symbol="WindowBulletList20" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="打开捕获数据库" Click="OnOpenCaptureClick">
                        <ui:SymbolIcon Symbol="FolderOpen20" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="设置" Click="OnOpenSettingsClick">
                        <ui:SymbolIcon Symbol="Settings20" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DevicePanelColumn" Width="232" />
                <ColumnDefinition x:Name="DeviceSplitterColumn" Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CommandSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="CommandPanelColumn" Width="540" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="2,0,2,8">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="设备工作区" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="新增设备" Command="{Binding AddProfileCommand}">
                                <ui:SymbolIcon Symbol="Add20" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="删除设备" Click="OnDeleteProfileClick">
                                <ui:SymbolIcon Symbol="Delete20" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,5" MinHeight="38">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4">
                                        <ui:SymbolIcon Symbol="BotSparkle20" Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding Transport.Kind}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="当前设备名称" />
                        <TextBox Margin="0,0,0,7" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                        <Button x:Name="ProfileActionsButton" Margin="0,0,0,6" Padding="8,6" HorizontalContentAlignment="Left" Click="OnOpenProfileActionsClick">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="ProfileActionsMenu">
                                    <MenuItem Header="导入 SSCOM / NetAssist" Click="OnImportLegacyClick" />
                                    <Separator />
                                    <MenuItem Header="导入设备配置 JSON" Click="OnImportDeviceProfileClick" />
                                    <MenuItem Header="导出当前设备 JSON" Click="OnExportDeviceProfileClick" />
                                    <Separator />
                                    <MenuItem Header="打开捕获数据库" Click="OnOpenCaptureClick" />
                                    <MenuItem Header="选择配置保存目录" Click="OnConfigureProfileDirectoryClick" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="MoreHorizontal20" />
                                <TextBlock Margin="8,0,0,0" Text="配置操作" />
                            </StackPanel>
                        </Button>
                        <Button Padding="8,6" HorizontalContentAlignment="Left" Command="{Binding SaveSelectedProfileCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Save20" />
                                <TextBlock Margin="8,0,0,0" Text="保存设备配置" />
                            </StackPanel>
                        </Button>
                        <TextBlock Margin="2,6,2,0"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding ProfileDirectory}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ProfileDirectory}" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="8,5"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <ListBox ItemsSource="{Binding WorkspaceModes}"
                             SelectedItem="{Binding SelectedWorkspaceMode}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="MinWidth" Value="108" />
                                <Setter Property="Height" Value="34" />
                                <Setter Property="Margin" Value="0,0,5,0" />
                                <Setter Property="Padding" Value="12,5" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1"
                        Padding="10,8"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:ToggleSwitch Margin="8,0" Content="自动重连" IsChecked="{Binding AutoReconnect}" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ToggleConnectionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="PlugConnected20" />
                                    <TextBlock Text="{Binding ConnectionButtonText}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <WrapPanel VerticalAlignment="Center">
                            <WrapPanel.Style>
                                <Style TargetType="WrapPanel">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Style>
                            <ComboBox Width="138"
                                      Margin="0,0,8,0"
                                      ItemsSource="{Binding AvailableTransportOptions}"
                                      SelectedItem="{Binding SelectedTransportOption}"
                                      DisplayMemberPath="Name" />

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Serial">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox Width="100"
                                          Margin="0,0,4,0"
                                          ItemsSource="{Binding SerialPorts}"
                                          SelectedValue="{Binding PortName}"
                                          SelectedValuePath="PortName"
                                          DisplayMemberPath="CompactDisplayName"
                                          ToolTip="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource Self}}" />
                                <Button Style="{StaticResource IconButtonStyle}" ToolTip="刷新串口" Command="{Binding RefreshPortsCommand}">
                                    <ui:SymbolIcon Symbol="ArrowSync20" />
                                </Button>
                                <ComboBox Width="120" Margin="4,0,6,0" IsEditable="True" ItemsSource="{Binding BaudRates}" Text="{Binding BaudRate}" />
                                <CheckBox Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" Content="DTR" IsChecked="{Binding DtrEnable}" />
                                <CheckBox VerticalAlignment="Center" FontSize="10" Content="RTS" IsChecked="{Binding RtsEnable}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="TcpClient">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Udp">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="160" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" ToolTip="远端地址" />
                                <TextBox Width="72" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding RemotePort}" ToolTip="远端端口" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="TcpServer">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="Udp">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="125" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LocalAddress}" ToolTip="本地地址" />
                                <TextBox Width="72" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LocalPort}" ToolTip="本地端口" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTransportOption.Kind}" Value="BleGatt">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox Width="245" Margin="0,0,4,0" ItemsSource="{Binding BleDevices}" SelectedItem="{Binding SelectedBleDevice}" DisplayMemberPath="DisplayName" />
                                <Button Style="{StaticResource IconButtonStyle}" ToolTip="扫描 BLE" Command="{Binding ScanBleCommand}">
                                    <ui:SymbolIcon Symbol="BluetoothSearching20" />
                                </Button>
                            </StackPanel>
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <TabControl Grid.Row="2" Margin="8,6,8,8" SelectedIndex="{Binding SelectedWorkspaceTabIndex}">
                    <TabItem Header="{Binding TerminalTabHeader}">
                        <Grid PreviewMouseWheel="OnTerminalPreviewMouseWheel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:ToggleSwitch Margin="0,0,10,0" Content="HEX 显示" FocusVisualStyle="{x:Null}" IsChecked="{Binding ReceiveAsHex}" ToolTip="仅切换通信记录显示，不影响发送格式" />
                                    <ui:ToggleSwitch Margin="0,0,10,0" Content="暂停显示" FocusVisualStyle="{x:Null}" IsChecked="{Binding IsPaused}" />
                                    <ui:ToggleSwitch Margin="0,0,8,0" Content="自动滚动" FocusVisualStyle="{x:Null}" IsChecked="{Binding AutoScroll}" />
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="保存显示内容" Click="OnSaveTerminalClick">
                                        <ui:SymbolIcon Symbol="Save20" />
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="清空显示" Command="{Binding ClearTerminalCommand}">
                                        <ui:SymbolIcon Symbol="Delete20" />
                                    </Button>
                                </StackPanel>
                                <Grid Width="260" HorizontalAlignment="Left">
                                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Padding="30,4,7,4" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="搜索方向、端点或内容" />
                                    <ui:SymbolIcon Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Symbol="Search20" IsHitTestVisible="False" />
                                </Grid>
                            </DockPanel>

                            <TabControl x:Name="TerminalDisplayTabs"
                                        Grid.Row="1"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        SelectionChanged="OnTerminalDisplaySelectionChanged">
                                <TabItem x:Name="TerminalTableTab" Header="表格">
                                    <ListView x:Name="TerminalList"
                                      ItemsSource="{Binding TerminalRecords}"
                                      SelectionMode="Extended"
                                      PreviewKeyDown="OnTerminalPreviewKeyDown"
                                      Background="{DynamicResource TerminalBackgroundBrush}"
                                      Foreground="{DynamicResource TerminalTextBrush}"
                                      BorderThickness="0"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="{Binding TerminalFontSize}"
                                       ScrollViewer.CanContentScroll="True"
                                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                       VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#315F58" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#284C48" />
                                </ListView.Resources>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制所选整行" Click="OnCopySelectedTerminalRowsClick" />
                                        <MenuItem Header="全选所有行" Click="OnSelectAllTerminalRowsClick" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="26" />
                                        <Setter Property="Padding" Value="3,0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn x:Name="TerminalTimeColumn" Width="122" Header="时间">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             Text="{Binding TimeText, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalDirectionColumn" Width="58" Header="方向">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             Text="{Binding DirectionText, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalEndpointColumn" Width="150" Header="端点">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             Text="{Binding Endpoint, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalSizeColumn" Width="66" Header="字节">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                             Text="{Binding Size, Mode=OneWay}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="TerminalContentColumn" Width="760" Header="内容">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Style="{StaticResource TerminalCellTextBoxStyle}"
                                                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}">
                                                        <TextBox.Text>
                                                            <MultiBinding Mode="OneWay" Converter="{StaticResource TerminalDisplayTextConverter}">
                                                                <Binding />
                                                                <Binding Path="DataContext.ReceiveAsHex" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                                    </ListView>
                                </TabItem>
                                <TabItem x:Name="TerminalPlainTextTab" Header="连续文本">
                                    <TextBox x:Name="TerminalPlainTextBox"
                                             Style="{StaticResource TerminalPlainTextBoxStyle}"
                                             FontSize="{Binding TerminalFontSize}">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="复制" Command="{x:Static ApplicationCommands.Copy}" />
                                                <MenuItem Header="全选" Click="OnSelectAllTerminalTextClick" />
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </TabItem>
                            </TabControl>

                            <Border Grid.Row="2" Margin="0,7,0,0" Padding="8" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="95" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Margin="0,0,6,6" ItemsSource="{Binding EncodingNames}" SelectedItem="{Binding SelectedEncodingName}" />
                                    <ComboBox Grid.Column="1" Margin="0,0,6,6" ItemsSource="{Binding LineEndings}" SelectedItem="{Binding SelectedLineEnding}" />
                                    <ComboBox Grid.Column="2" Margin="0,0,6,6" ItemsSource="{Binding ChecksumKinds}" SelectedItem="{Binding SelectedSendChecksum}" />
                                    <ui:ToggleSwitch Grid.Column="3" Margin="0,0,6,6" HorizontalAlignment="Left" Content="HEX 发送" IsChecked="{Binding SendAsHex}" ToolTip="开启后按十六进制字节解析发送框内容" />
                                    <Button Grid.Column="4" Margin="3,0,0,6" Padding="10,4" Click="OnSendFileClick">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="DocumentArrowUp20" />
                                            <TextBlock Margin="6,0,0,0" Text="文件" />
                                        </StackPanel>
                                    </Button>
                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" MinHeight="54" MaxHeight="110" Padding="8,6" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="1" Grid.Column="4" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SendCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Margin="0,0,6,0" Symbol="Send20" />
                                            <TextBlock Text="发送" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="帧解析" Visibility="{Binding IsFrameWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,7">
                                <ComboBox Width="115" Margin="0,0,6,0" ItemsSource="{Binding FramingModes}" SelectedItem="{Binding SelectedFramingMode}" />
                                <TextBox Width="110" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding DelimiterHex}" ToolTip="分隔符 HEX" />
                                <TextBox Width="68" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding FixedFrameLength}" ToolTip="固定帧长" />
                                <TextBox Width="60" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LengthFieldOffset}" ToolTip="长度字段偏移" />
                                <TextBox Width="60" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding LengthFieldSize}" ToolTip="长度字段宽度" />
                                <TextBox Width="65" Margin="0,0,6,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding IdleGapMs}" ToolTip="空闲间隔 ms" />
                                <Button Padding="12,5" Command="{Binding ApplyFramingOptionsCommand}">应用分帧</Button>
                            </WrapPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ListView ItemsSource="{Binding FrameRecords}" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="90" Header="时间" DisplayMemberBinding="{Binding TimeText}" />
                                            <GridViewColumn Width="55" Header="长度" DisplayMemberBinding="{Binding Length}" />
                                            <GridViewColumn Width="360" Header="HEX" DisplayMemberBinding="{Binding Hex}" />
                                            <GridViewColumn Width="360" Header="字段" DisplayMemberBinding="{Binding Summary}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <Grid Grid.Column="2" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="设备帧模板 JSON" />
                                    <TextBox Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" FontFamily="Cascadia Mono, Consolas" FontSize="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Text="{Binding FrameTemplateJson, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="2" Margin="0,7,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button Margin="0,0,5,0" Padding="9,5" Click="OnImportFrameTemplateClick">导入</Button>
                                        <Button Margin="0,0,5,0" Padding="9,5" Click="OnExportFrameTemplateClick">导出</Button>
                                        <Button Padding="10,5" Command="{Binding ApplyFrameTemplateCommand}">校验并应用模板</Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="曲线" Visibility="{Binding IsChartWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="清空曲线" Click="OnClearChartClick">
                                        <ui:SymbolIcon Symbol="Delete20" />
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="导出 PNG" Click="OnExportChartClick">
                                        <ui:SymbolIcon Symbol="Save20" />
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="导出 CSV" Click="OnExportChartCsvClick">
                                        <ui:SymbolIcon Symbol="DocumentCsv20" />
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:ToggleSwitch Margin="0,0,8,0" Content="从文本提取数值" IsChecked="{Binding ChartAutoExtract}" />
                                    <TextBox Width="260" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ChartValuePattern, UpdateSourceTrigger=PropertyChanged}" ToolTip="数值正则表达式" />
                                </StackPanel>
                            </DockPanel>
                            <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="4">
                                <scott:WpfPlot x:Name="RealtimePlot" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Modbus" Visibility="{Binding IsModbusWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="站号" />
                                <TextBox Width="55" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusUnitId}" />
                                <ComboBox Width="150" Margin="0,0,8,0" ItemsSource="{Binding ModbusFunctions}" SelectedItem="{Binding SelectedModbusFunction}" />
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="地址" />
                                <TextBox Width="70" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusAddress}" />
                                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="数量/值" />
                                <TextBox Width="75" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusQuantityOrValue}" />
                                <TextBox Width="210" Margin="0,0,8,0" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusValues}" ToolTip="多值使用逗号或空格分隔" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SendModbusCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Send20" />
                                        <TextBlock Text="发送请求" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="270" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding ModbusRegisters}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="170" Header="寄存器地址" Binding="{Binding AddressText}" IsReadOnly="True" />
                                        <DataGridTextColumn Width="120" Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Width="120" Header="HEX" Binding="{Binding Value, StringFormat=0x{0:X4}}" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <StackPanel Grid.Column="2" Margin="10,4">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="从站模拟" />
                                    <ui:ToggleSwitch Content="启用 RTU/TCP 响应" IsChecked="{Binding ModbusSlaveEnabled}" />
                                    <TextBlock Margin="0,14,0,4" Style="{StaticResource SectionLabelStyle}" Text="事务编号" />
                                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ModbusTransactionId}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="BLE GATT" Visibility="{Binding IsBluetoothWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Padding="10,5" Command="{Binding ScanBleCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="BluetoothSearching20" />
                                        <TextBlock Text="扫描 4 秒" />
                                    </StackPanel>
                                </Button>
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding BleDevices.Count, StringFormat=发现 {0} 个设备}" />
                            </DockPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1.05*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <ListBox ItemsSource="{Binding BleDevices}" SelectedItem="{Binding SelectedBleDevice}" DisplayMemberPath="DisplayName" />
                                    <Button Grid.Row="1" Margin="0,7" Padding="10,5" HorizontalAlignment="Left" Command="{Binding BrowseGattCommand}">浏览所选设备 GATT</Button>
                                    <TreeView Grid.Row="2" ItemsSource="{Binding GattServices}" SelectedItemChanged="OnGattTreeSelectedItemChanged">
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type infra:BleGattServiceInfo}" ItemsSource="{Binding Characteristics}">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas" Text="{Binding DisplayName}" />
                                            </HierarchicalDataTemplate>
                                            <DataTemplate DataType="{x:Type infra:BleGattCharacteristicInfo}">
                                                <TextBlock Margin="12,0,0,0" FontFamily="Cascadia Mono, Consolas" Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </Grid>
                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                                <StackPanel Grid.Column="2" Margin="12,4">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="服务 UUID" />
                                    <TextBox Margin="0,0,0,10" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleServiceUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="写特征值 UUID" />
                                    <TextBox Margin="0,0,0,10" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleWriteUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="读特征值 UUID" />
                                    <DockPanel Margin="0,0,0,10">
                                        <Button DockPanel.Dock="Right" Margin="6,0,0,0" Padding="10,4" Command="{Binding ReadBleCommand}">读取</Button>
                                        <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleReadUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="通知特征值 UUID" />
                                    <TextBox Margin="0,0,0,10" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BleNotifyUuid, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:ToggleSwitch Content="无响应写入" IsChecked="{Binding BleWriteWithoutResponse}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent" />

            <Border Grid.Column="4"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="2,0,2,8">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionLabelStyle}"
                                   FontSize="15"
                                   Margin="0,0,0,4"
                                   Text="快捷指令" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="删除勾选的快捷指令"
                                    Command="{Binding DeleteSelectedQuickCommandsCommand}">
                                <ui:SymbolIcon Symbol="Delete20" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="新增命令" Command="{Binding AddQuickCommandCommand}">
                                <ui:SymbolIcon Symbol="Add20" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid Margin="0,0,6,0">
                            <TextBox Height="28"
                                     Padding="27,3,6,3"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding QuickCommandSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="按名称或内容查找快捷命令" />
                            <ui:SymbolIcon Margin="7,0,0,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Symbol="Search20"
                                           IsHitTestVisible="False" />
                        </Grid>
                        <Button x:Name="QuickCommandSortButton"
                                Grid.Column="1"
                                Height="30"
                                Padding="10,4"
                                HorizontalContentAlignment="Stretch"
                                ToolTip="快捷命令排序方式"
                                Click="OnOpenQuickCommandSortMenuClick">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="QuickCommandSortMenu">
                                    <MenuItem Header="使用频率" Tag="使用频率" Click="OnQuickCommandSortMenuItemClick" />
                                    <MenuItem Header="最近使用" Tag="最近使用" Click="OnQuickCommandSortMenuItemClick" />
                                    <MenuItem Header="手动顺序" Tag="手动顺序" Click="OnQuickCommandSortMenuItemClick" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <DockPanel LastChildFill="True">
                                <ui:SymbolIcon DockPanel.Dock="Right" Symbol="ChevronDown20" />
                                <TextBlock VerticalAlignment="Center" FontSize="12" Text="{Binding SelectedQuickCommandSort}" />
                            </DockPanel>
                        </Button>
                    </Grid>

                    <ListBox x:Name="QuickCommandsList"
                             Grid.Row="2"
                             ItemsSource="{Binding QuickCommandsView}"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="OnQuickCommandPreviewMouseLeftButtonDown"
                              PreviewMouseMove="OnQuickCommandPreviewMouseMove"
                             PreviewDragOver="OnQuickCommandDragOver"
                             PreviewDragLeave="OnQuickCommandDragLeave"
                             PreviewDrop="OnQuickCommandDrop"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="72" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid>
                                                <Border x:Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                </Border>
                                                <Border Height="3"
                                                        Panel.ZIndex="1000"
                                                        VerticalAlignment="Top"
                                                        Background="{DynamicResource ButtonForegroundBrush}"
                                                        Visibility="{Binding IsDropTarget, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        IsHitTestVisible="False" />
                                                <Border Height="3"
                                                        Panel.ZIndex="1000"
                                                        VerticalAlignment="Bottom"
                                                        Background="{DynamicResource ButtonForegroundBrush}"
                                                        Visibility="{Binding IsDropTargetAfter, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        IsHitTestVisible="False" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="{x:Null}" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#120078D4" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#360078D4" />
                                                </MultiDataTrigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#220078D4" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#700078D4" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="72">
                                    <Border Height="64"
                                            Padding="2,3"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30" />
                                                <RowDefinition Height="28" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="28" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Height="27"
                                                     Margin="0,0,4,3"
                                                     Padding="5,3"
                                                     FontSize="12"
                                                     FontWeight="SemiBold"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="快捷命令名称" />
                                            <TextBox Grid.Column="1"
                                                     Height="27"
                                                     Margin="0,0,4,3"
                                                     Padding="5,3"
                                                     FontFamily="Cascadia Mono, Consolas"
                                                     FontSize="12"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding Payload, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding Payload}" />
                                            <Button x:Name="QuickCommandDragHandle"
                                                    Grid.Column="2"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Width="27"
                                                    Height="27"
                                                    Margin="0,0,0,3"
                                                    Cursor="SizeAll"
                                                    Focusable="False"
                                                    ToolTip="按住拖动调整顺序">
                                                <ui:SymbolIcon Symbol="ArrowMove20" />
                                            </Button>

                                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" MinWidth="492">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="32" />
                                                <ColumnDefinition Width="Auto" MinWidth="64" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="112" />
                                                <ColumnDefinition Width="112" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox MinWidth="32"
                                                      Margin="2,0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      FontSize="10"
                                                      IsChecked="{Binding IsSelectedForBulkDelete}"
                                                      ToolTip="勾选后可批量删除" />
                                            <CheckBox Grid.Column="1"
                                                      MinWidth="60"
                                                      Margin="2,0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Content="HEX"
                                                      FontSize="10"
                                                      IsChecked="{Binding IsHex}"
                                                      Command="{Binding DataContext.ApplyQuickCommandHexModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="开启后按十六进制字节解析快捷指令内容" />
                                            <TextBox Grid.Column="2"
                                                     Height="25"
                                                     Margin="0,1,3,1"
                                                     Padding="3,2"
                                                     FontSize="10"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding RepeatIntervalMs}"
                                                     ToolTip="循环发送间隔，单位 ms" />
                                            <ComboBox Grid.Column="3"
                                                      Height="25"
                                                      Margin="0,1,3,1"
                                                      Padding="2,0"
                                                      FontSize="10"
                                                      ItemsSource="{Binding DataContext.LineEndings, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding LineEnding}"
                                                      ToolTip="行尾追加方式" />
                                            <ComboBox Grid.Column="4"
                                                      Height="25"
                                                      Margin="0,1,3,1"
                                                      Padding="2,0"
                                                      FontSize="10"
                                                      ItemsSource="{Binding DataContext.ChecksumKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding Checksum}"
                                                      ToolTip="自动追加校验" />
                                            <Button Grid.Column="5"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Width="27"
                                                    Height="25"
                                                    Margin="0,1,1,1"
                                                    ToolTip="发送"
                                                    Command="{Binding DataContext.SendQuickCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Send20" Width="16" Height="16" FontSize="16" />
                                            </Button>
                                            <Button Grid.Column="6"
                                                    Width="27"
                                                    Height="25"
                                                    Margin="0,1,1,1"
                                                    ToolTip="开始或停止循环发送"
                                                    Command="{Binding DataContext.ToggleQuickRepeatCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <ui:SymbolIcon Symbol="ArrowRepeatAll20" Width="16" Height="16" FontSize="16" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRepeating}" Value="True">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ui:SymbolIcon Symbol="Pause20" Width="16" Height="16" FontSize="16" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Grid.Column="7"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Width="27"
                                                    Height="25"
                                                    Margin="0,1,1,1"
                                                    ToolTip="删除"
                                                    Command="{Binding DataContext.DeleteQuickCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Delete20" />
                                            </Button>
                                            <Border Grid.Column="8" Margin="1" ToolTip="{Binding UsageText}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           Text="{Binding UsageShortText}" />
                                            </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Expander Grid.Row="3"
                              Margin="0,7,0,0"
                              Header="命令变量（可选）"
                              ToolTip="每行填写 name=value，快捷命令中使用 ${name} 引用；例如 id=01 对应 ${id}。">
                        <TextBox Height="64"
                                 Margin="0,5,0,0"
                                 Padding="7,5"
                                 AcceptsReturn="True"
                                 FontFamily="Cascadia Mono, Consolas"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding VariablesText, UpdateSourceTrigger=PropertyChanged}" />
                    </Expander>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="12,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding RateText}" />
                    <TextBlock Margin="12,0" Foreground="{DynamicResource ReceiveBrush}" Text="{Binding ReceivedBytes, StringFormat=RX {0:N0}}" />
                    <TextBlock Margin="12,0" Foreground="{DynamicResource SendBrush}" Text="{Binding SentBytes, StringFormat=TX {0:N0}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#8B9690" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#20A36A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
